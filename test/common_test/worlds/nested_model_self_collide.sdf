      <!-- PC Test (Parent-Child - Parent Platform) -->
      <link name="parent_platform_pc">
        <pose>0 1.5 0.5 0 0 0</pose>
        <collision name="col">
          <geometry><box><size>0.5 0.5 0.1</size></box></geometry>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.5 0.5 0.1</size></box></geometry>
          <material>
