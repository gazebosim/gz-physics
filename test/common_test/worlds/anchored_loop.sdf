      <joint name="joint4" type="prismatic">
        <pose>0 0 0.5 0.6 0 0</pose>
        <parent>world</parent>
        <child>link3</child>
        <axis>
          <xyz>0 1 0</xyz>
        </axis>
      </joint>
      <plugin
        filename="gz-sim-joint-state-publisher-system"
        name="gz::sim::systems::JointStatePublisher">
        <!-- Optional: restrict to specific joints. Omit to publish ALL joints. -->
        <joint_name>joint3</joint_name>
        <!-- Optional: custom topic. Default is the long world/model path below. -->
        <topic>joint_states</topic>
      </plugin>
