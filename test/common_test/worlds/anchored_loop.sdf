<?xml version="1.0" ?>
<sdf version='1.6'>
  <world name="default">
    <gravity>0 -9.8 0</gravity>
    <physics type="dart">
      <dart>
        <solver>
          <solver_type>pgs</solver_type>
        </solver>
      </dart>
